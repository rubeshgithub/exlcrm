# .env.example — Copy to .env and fill in values

# === Application ===
APP_NAME=EXL-CRM
APP_ENV=production
APP_PORT=8000
APP_SECRET_KEY=generate-with-openssl-rand-hex-32
APP_URL=https://exlcrm.com

# === MongoDB Atlas (Toronto, CA-Central) ===
MONGODB_URL=mongodb+srv://username:***@cluster0.xxxxx.mongodb.net/exlcrm?retryWrites=true&w=majority

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === AWS (ca-central-1 - Montreal) ===
AWS_REGION=ca-central-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET=exlcrm-documents
SES_FROM_EMAIL=app@exlcrm.com

# === DocuSeal ===
DOCU_SEAL_URL=http://docuseal:55017
DOCU_SEAL_SECRET=your-docuseal-secret

# === InfoBIP SMS ===
INFOBIP_API_KEY=your-infobip-api-key
INFOBIP_BASE_URL=https://api.infobip.com

# === Stripe ===
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PROFESSIONAL=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# === Frontend ===
NEXT_PUBLIC_API_URL=https://exlcrm.com
NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32
NEXTAUTH_URL=https://exlcrm.com